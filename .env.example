# ==========================================
# Agentic OS - Configuration
# ==========================================
# Ce fichier est automatiquement copié par deploy-agentic-os.sh
# Remplissez uniquement les valeurs nécessaires.

# ==========================================
# AgentMemory (Core)
# ==========================================
AGENTMEMORY_SECRET=REMPLACER_PAR_UN_SECRET_GENERE
AGENTMEMORY_III_VERSION=0.11.2

# LLM Provider (choisir un seul)
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=...
# OPENAI_API_KEY=sk-...

# Embedding Provider (auto-détecté ou override)
# EMBEDDING_PROVIDER=local
# VOYAGE_API_KEY=...

# Features AgentMemory
CONSOLIDATION_ENABLED=true
LESSON_DECAY_ENABLED=true
OBSIDIAN_AUTO_EXPORT=true
# AGENTMEMORY_SLOTS=false
# AGENTMEMORY_REFLECT=false
# AGENTMEMORY_INJECT_CONTEXT=false
# GRAPH_EXTRACTION_ENABLED=false

# ==========================================
# Obsidian (Second Brain / Wiki LLM)
# ==========================================
CHEMIN_VAULT_OBSIDIAN=./memory/storage/obsidian
AGENTMEMORY_EXPORT_ROOT=./memory/storage/obsidian

# ==========================================
# n8n (Automatisation)
# ==========================================
DOMAIN_NAME=localhost
PROTOCOL=http

# ==========================================
# VPS (Optionnel - si déploiement distant)
# ==========================================
# DOMAIN_NAME=votre-domaine.com
# PROTOCOL=https

# ==========================================
# Sécurité et Guardrails
# ==========================================
NIVEAU_APPROBATION_HUMAINE=STRICT
AGENTS_AUTORISES=Claude Code,Codex,Antigravity
OUTILS_AUTORISES=gh,npm,node,python,n8n
ENVIRONNEMENT_CIBLE=dev
BUDGET_API_MENSUEL=50.00
