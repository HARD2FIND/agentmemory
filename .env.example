# Configuration de l'Agentic OS

# ==========================================
# Couche Mémoire (AgentMemory & Obsidian)
# ==========================================
# Chemin absolu vers le dossier Obsidian Vault
CHEMIN_VAULT_OBSIDIAN=/chemin/vers/votre/obsidian/vault

# ==========================================
# Couche Automatisation (n8n)
# ==========================================
# URL de l'instance n8n auto-hébergée
URL_VPS_N8N=http://votre-vps-n8n:5678
# Limites d'automatisation (ex: max_runs_per_day)
LIMITES_AUTOMATISATION=100

# ==========================================
# Sécurité et Guardrails
# ==========================================
# Gestionnaire de secrets utilisé (ex: AWS_SECRETS_MANAGER, ENV, VAULT)
SECRETS_MANAGER=ENV
# Niveau d'approbation humaine (ex: STRICT, MODERATE, NONE)
NIVEAU_APPROBATION_HUMAINE=STRICT
# Liste des agents autorisés (séparés par des virgules)
AGENTS_AUTORISES=Claude Code,Codex,Antigravity
# Liste des outils autorisés (séparés par des virgules)
OUTILS_AUTORISES=gh,npm,node,python,n8n,cli-printing-press
# Environnement cible (dev, staging, prod)
ENVIRONNEMENT_CIBLE=dev

# ==========================================
# Budgets et Quotas API
# ==========================================
# Budget mensuel maximum en USD
BUDGET_API_MENSUEL=50.00

# ==========================================
# Clés API (Remplacer par les vraies valeurs dans .env)
# ==========================================
GITHUB_TOKEN=votre_token_github_ici
ANTHROPIC_API_KEY=votre_cle_api_anthropic_ici
OPENAI_API_KEY=votre_cle_api_openai_ici
N8N_API_KEY=votre_cle_api_n8n_ici
